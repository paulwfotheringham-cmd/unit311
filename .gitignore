# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
*.log
.deploy*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# environment & secrets — never commit
.env
.env.*
!.env.example
*.tmp
*-secret.tmp
.env-*-payload.json
.env-api-payload.json
.env-copy-*.json

# local credential material
wise-keys/
*.p12
*.pfx
id_rsa
id_rsa.pub

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Capacitor / Android (generated locally; CI builds fresh)
/mobile/node_modules
/mobile/android
/mobile/.capacitor

# editor / agent local state
.cursor/
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# one-off local dump / inspect helpers (never commit)
scripts/_*.mjs
scripts/dump-*.mjs
scripts/inspect-vercel-*.mjs

# OS / trash
$RECYCLE.BIN/
Desktop.ini
.env*
