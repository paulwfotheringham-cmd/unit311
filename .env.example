# =============================================================================
# Unit311 Central — environment variables
# Copy to .env.local for local development. Never commit real values.
# Production values live in the Vercel project `unit311central`.
# =============================================================================

# --- Core (required) ---------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Public site URL (apex). Used for emails, redirects, and absolute links.
NEXT_PUBLIC_SITE_URL=https://unit311central.com
NEXT_PUBLIC_SITE_NAME=Unit311
# NEXT_PUBLIC_SITE_LOGO_PATH=/images/unit311central.png

# Session signing (required in production; local/dev has a non-public placeholder if unset)
# Never use SUPABASE_ANON_KEY for AUTH_SECRET — the anon key is a public client value.
AUTH_SECRET=choose-a-long-random-secret

# --- Database / migrations (ops only — server-side) --------------------------
# Prefer the Supabase Management API token for migration helpers.
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_DB_PASSWORD=
# DATABASE_URL=
# INTERNAL_FILES_SETUP_SECRET=choose-a-long-random-secret

# --- Cron / webhooks ---------------------------------------------------------
# CRON_SECRET=choose-a-long-random-secret
# WISE_WEBHOOK_SECRET=
# WHATSAPP_WEBHOOK_SECRET=

# --- Email (Zoho — server-side only) -----------------------------------------
# ZOHO_INFO_EMAIL=info@unit311central.com
# ZOHO_INFO_PASSWORD=your-app-specific-password
# ZOHO_PAUL_EMAIL=paul@unit311central.com
# ZOHO_PAUL_PASSWORD=your-app-specific-password
# ZOHO_IMAP_HOST=imap.zoho.eu
# ZOHO_IMAP_PORT=993
# ZOHO_SMTP_HOST=smtp.zoho.eu
# ZOHO_SMTP_PORT=465

# --- WhatsApp notifications --------------------------------------------------
# WHATSAPP_NOTIFY_PHONE=34657106176
# CALLMEBOT_API_KEY=
# TEXTMEBOT_API_KEY=
# FOUNDER_BOOKING_WHATSAPP_PHONE=

# --- Wise Business (Financials → Treasury) -----------------------------------
# WISE_API_TOKEN=
# WISE_PROFILE_ID=
# WISE_API_BASE_URL=https://api.wise.com
# WISE_API_PRIVATE_KEY_B64=
# WISE_API_PRIVATE_KEY=

# --- AI (Executive Assistant) ------------------------------------------------
# On Vercel production, AI Gateway OIDC is preferred (no key required).
# AI_GATEWAY_API_KEY=
# OPENAI_API_KEY=

# --- WebODM ------------------------------------------------------------------
# NEXT_PUBLIC_WEBODM_URL=https://your-webodm-host.example.com
# WEBODM_URL=https://your-webodm-host.example.com
# WEBODM_USERNAME=
# WEBODM_PASSWORD=

# --- Local / safety ----------------------------------------------------------
# DEV_ALLOW_REPEAT_SIGNUP=true
# EXECUTIVE_DISCOVERY_CHANNEL_NAME=Executive Discovery Meetings

# --- Demo surface (same build as Internal; content tenancy only) -------------
# See docs/DEMO_RELEASE_MODEL.md
# DEMO_WORKSPACE_SLUG=demo
# Optional comma-separated module keys to limit Demo nav visibility (empty = show all)
# DEMO_VISIBLE_MODULES=
